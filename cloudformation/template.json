{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "CloudFormation template to create an S3 bucket",
    "Resources": {
        "S3Bucket": {
            "Type": "AWS::S3::Bucket",
            "Properties": {
                "BucketName": "aws-serverless-data-pipeline-s3-bucket"
            }
        }
    },
    "Outputs": {
        "BucketName": {
            "Value": { "Ref": "S3Bucket" }
        }
    }
}