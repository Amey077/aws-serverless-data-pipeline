{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Serverless Data Pipeline",
  "Resources": {
    "CodeBucket": {
        "Type": "AWS::S3::Bucket",
        "Properties": {
            "BucketName": "lambda-code-s3-bucket",
            "VersioningConfiguration": {
                "Status": "Enabled"
            }
        }
    },
    "S3Bucket": {
    "Type": "AWS::S3::Bucket",
    "Properties": {
        "BucketName": "aws-serverless-data-pipeline-s3-bucket",
        "VersioningConfiguration": {
                "Status": "Enabled"
            }
        }
    }
  },
    "Outputs": {
        "CodeBucketName": {
            "Value": { "Ref": "CodeBucket" },
            "Description": "S3 bucket for Lambda code"
        },
        "S3BucketName": {
            "Value": { "Ref": "S3Bucket" },
            "Description": "S3 bucket for data storage"
        }
    }
}