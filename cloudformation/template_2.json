{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Serverless Data Pipeline",
  "Resources": {
    "LambdaExecutionRole": {
    "Type": "AWS::IAM::Role",
    "Properties": {
        "AssumeRolePolicyDocument": {
            "Version": "2012-10-17",
            "Statement": [
                {
                "Effect": "Allow",
                "Principal": {
                    "Service": "lambda.amazonaws.com"
                },
                "Action": "sts:AssumeRole"
                }
            ]
        },
        "Policies": [
            {
                "PolicyName": "S3AccessPolicy",
                "PolicyDocument": {
                "Version": "2012-10-17",
                "Statement": [
                    {
                        "Effect": "Allow",
                        "Action": [
                            "s3:GetObject",
                            "s3:PutObject",
                            "s3:DeleteObject"
                        ],
                        "Resource": {
                            "Fn::Sub": [
                                "arn:aws:s3:::${S3Bucket}/*",
                                {
                                    "S3Bucket": { "Fn::ImportValue": "S3BucketName" }
                                }
                            ]
                        }
                    },
                    {
                        "Effect": "Allow",
                        "Action": [
                            "s3:ListBucket"
                        ],
                        "Resource": {
                            "Fn::Sub": [
                                "arn:aws:s3:::${S3Bucket}",
                                {
                                    "S3Bucket": { "Fn::ImportValue": "S3BucketName" }
                                }
                            ]
                        }
                    }
                ]
                }
            }
        ],
        "ManagedPolicyArns": [
            "arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole"
            ]
        }
    },
    "RetrieveLambda": {
        "Type": "AWS::Lambda::Function",
        "Properties": {
            "FunctionName": "retrieve-data",
            "Runtime": "python3.9",
            "Handler": "retrieve.handler",
            "Role": { "Fn::GetAtt": ["LambdaExecutionRole", "Arn"] },
            "Timeout": 120,
            "MemorySize": 512,
            "Code": {
                "S3Bucket": { "Fn::ImportValue": "S3BucketName" },
                "S3Key": "lambda/retrieve.zip"
            },
            "Environment": {
                "Variables": {
                    "BUCKET_NAME": { "Fn::ImportValue": "S3BucketName" }
                }
            }
        }
    },
    "UncompressLambda": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
            "FunctionName": "uncompress-data",
            "Runtime": "python3.9",
            "Handler": "uncompress.handler",
            "Role": { "Fn::GetAtt": ["LambdaExecutionRole", "Arn"] },
            "Timeout": 120,
            "MemorySize": 512,
            "Code": {
                "S3Bucket": { "Fn::ImportValue": "S3BucketName" },
                "S3Key": "lambda/uncompress.zip"
            },
            "Environment": {
                "Variables": {
                    "BUCKET_NAME": { "Fn::ImportValue": "S3BucketName" }
                }
            }
        }
    },
    "TransformLambda": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
            "FunctionName": "transform-data",
            "Runtime": "python3.9",
            "Handler": "transform.handler",
            "Role": { "Fn::GetAtt": ["LambdaExecutionRole", "Arn"] },
            "Timeout": 120,
            "MemorySize": 512,
            "Code": {
                "S3Bucket": { "Fn::ImportValue": "S3BucketName" },
                "S3Key": "lambda/transform.zip"
            },
            "Environment": {
                "Variables": {
                    "BUCKET_NAME": { "Fn::ImportValue": "S3BucketName" }
                }
            }
        }
    },
    "UncompressPermission": {
        "Type": "AWS::Lambda::Permission",
        "Properties": {
            "FunctionName": { "Ref": "UncompressLambda" },
            "Action": "lambda:InvokeFunction",
            "Principal": "s3.amazonaws.com",
            "SourceArn": {
                "Fn::Sub": [
                    "arn:aws:s3:::${S3Bucket}",
                    {
                        "S3Bucket": { "Fn::ImportValue": "S3BucketName" }
                    }
                ]
            }
        }
    },
    "TransformPermission": {
        "Type": "AWS::Lambda::Permission",
        "Properties": {
            "FunctionName": { "Ref": "TransformLambda" },
            "Action": "lambda:InvokeFunction",
            "Principal": "s3.amazonaws.com",
            "SourceArn": {
                "Fn::Sub": [
                    "arn:aws:s3:::${S3Bucket}",
                    {
                        "S3Bucket": { "Fn::ImportValue": "S3BucketName" }
                    }
                ]
            }
        }
    },
    "GlueTable": {
        "Type": "AWS::Glue::Table",
        "Properties": {
            "DatabaseName": "aws_data_pipeline_db",
            "CatalogId": { "Ref": "AWS::AccountId" },
            "TableInput": {
            "Name": "aws_data_table",
            "TableType": "EXTERNAL_TABLE",
            "Parameters": {
                "classification": "parquet"
            },
            "StorageDescriptor": {
                "Columns": [
                { "Name": "region", "Type": "string" },
                { "Name": "item_type", "Type": "string" },
                { "Name": "sales_channel", "Type": "string" },
                { "Name": "order_priority", "Type": "string" },
                { "Name": "order_date", "Type": "date" },
                { "Name": "order_id", "Type": "int" },
                { "Name": "ship_date", "Type": "date" },
                { "Name": "units_sold", "Type": "int" },
                { "Name": "unit_price", "Type": "double" },
                { "Name": "unit_cost", "Type": "double" },
                { "Name": "total_revenue", "Type": "double" },
                { "Name": "total_cost", "Type": "double" },
                { "Name": "total_profit", "Type": "double" }
                ],
                "Location": {
                    "Fn::Sub": [
                        "s3://${S3Bucket}/staging/",
                        {
                            "S3Bucket": { "Fn::ImportValue": "S3BucketName" }
                        }
                    ]
                },
                "InputFormat": "org.apache.hadoop.hive.ql.io.parquet.MapredParquetInputFormat",
                "OutputFormat": "org.apache.hadoop.hive.ql.io.parquet.MapredParquetOutputFormat",
                "SerdeInfo": {
                "SerializationLibrary": "org.apache.hadoop.hive.ql.io.parquet.serde.ParquetHiveSerDe"
                }
            },
            "PartitionKeys": [
                { "Name": "country", "Type": "string" }
            ]
            }
        }
    }
  }
}